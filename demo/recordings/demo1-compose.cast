{"version": 2, "width": 80, "height": 24, "timestamp": 1775806910, "env": {"SHELL": "/bin/bash", "TERM": "xterm-256color"}, "title": "Noether: Compose and Execute"}
[0.00455, "o", "\u001b[H\u001b[2J\u001b[3J"]
[0.005028, "o", "\u001b[36mAn AI agent needs to count rows in a CSV file.\u001b[0m\r\n"]
[1.007833, "o", "\u001b[36mInstead of writing Python, it asks Noether:\u001b[0m\r\n"]
[2.014382, "o", "\u001b[36m\u001b[0m\r\n"]
[3.020428, "o", "\u001b[36m  noether compose \"parse CSV data and count the number of rows\"\u001b[0m\r\n"]
[6.03211, "o", "\u001b[36m\u001b[0m\r\n"]
[7.038572, "o", "\u001b[36mNoether searches 500+ stages, finds csv_parse and list_length,\u001b[0m\r\n"]
[8.045843, "o", "\u001b[36msends them to the LLM, and gets back a 2-stage pipeline:\u001b[0m\r\n"]
[9.05222, "o", "\u001b[36m\u001b[0m\r\n"]
[10.058026, "o", "\u001b[36m  csv_parse → list_length\u001b[0m\r\n"]
[11.061724, "o", "\u001b[36m  Record{text,has_header,delimiter} → List<Map> → Number\u001b[0m\r\n"]
[14.074539, "o", "\u001b[36m\u001b[0m\r\n"]
[15.080308, "o", "\u001b[36mThe type checker validates every edge. Then the executor runs it:\u001b[0m\r\n"]
[17.098442, "o", "\r\n$ n"]
