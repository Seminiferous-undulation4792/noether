[51.042147, "o", "\u001b[36m\u001b[0m\r\n"]
[52.04911, "o", "\u001b[36mCalling the API:\u001b[0m\r\n"]
[53.054369, "o", "\r\n  $ curl -X POST http://localhost:8092/predict \\\r\n      -d '[{\"sepal_l\":5.1,\"sepal_w\":3.5,\"petal_l\":1.4,\"petal_w\":0.2}]'\r\n\r\n"]
[54.335147, "o", "POST /predict → 200 OK\r\n"]
[54.374995, "o", "    → setosa        (sepal=5.1, petal=1.4)\r\n    → versicolor    (sepal=7.0, petal=4.7)\r\n    → virginica     (sepal=6.3, petal=6.0)\r\n    1267ms\r\n"]
[56.386333, "o", "\r\n  $ curl -X POST http://localhost:8092/importance \\\r\n      -d '{\"model_path\":\"/tmp/iris_rf.pkl\"}'\r\n\r\n"]
[57.612756, "o", "POST /importance → 200 OK\r\n"]
[57.642437, "o", "    petal_l    0.413  ████████████\r\n    petal_w    0.307  █████████\r\n    sepal_l    0.256  ███████\r\n    sepal_w    0.024  \r\n"]
[60.654398, "o", "\u001b[36m\u001b[0m\r\n"]
[61.660959, "o", "\u001b[36mEnd-to-end: train → evaluate → serve. No Flask. No Docker.\u001b[0m\r\n"]
[62.668255, "o", "\u001b[36mJust composition graphs + noether serve.\u001b[0m\r\n"]
